<%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>

  <main class="page">
    <section class="form-wrap">
      <div class="form-card">
        <span class="eyebrow">Host with StayHub</span>
        <h1>List a residence with character.</h1>
        <p class="form-intro">Add the essential details and upload at least two residence photos. StayHub listings feel best when guests can browse the rooms before opening the full details.</p>

        <% if (errorMessage) { %>
          <div class="form-error"><%= errorMessage %></div>
        <% } %>

        <form action="/host/add-home" method="post" enctype="multipart/form-data" class="stay-form" id="stayForm">
          <div class="field">
            <label for="housename">Residence name</label>
            <input id="housename" type="text" name="housename" placeholder="The Green Drawing Room" required>
          </div>

          <div class="form-grid">
            <div class="field">
              <label for="location">Location</label>
              <input id="location" type="text" name="location" placeholder="Udaipur, Rajasthan" required>
            </div>
            <div class="field">
              <label for="Rooms">Nightly price</label>
              <input id="Rooms" type="number" name="Rooms" placeholder="4500" min="0" required>
            </div>
          </div>

          <div class="form-grid">
            <div class="field">
              <label for="Rating">Rating</label>
              <input id="Rating" type="number" step="0.1" max="5" min="0" name="Rating" placeholder="4.8">
            </div>
            <div class="field upload-field">
              <label for="images">Residence photos</label>
              <input id="images" type="file" name="images" accept="image/*" multiple required>
              <small id="imageHelp">Choose at least 2 images. Maximum 8, under 15MB each. Landscape 4:3 photos look best.</small>
            </div>
          </div>

          <div class="upload-preview" id="uploadPreview" aria-live="polite"></div>

          <div class="field">
            <label for="description">Description</label>
            <textarea name="description" id="description" placeholder="Describe the mood, rooms, nearby landmarks, and the kind of guest this stay suits."></textarea>
          </div>

          <button type="submit" class="button" id="publishButton" disabled>Publish residence</button>
        </form>
      </div>
    </section>
  </main>
  <script>
    const imageInput = document.getElementById("images");
    const imageHelp = document.getElementById("imageHelp");
    const uploadPreview = document.getElementById("uploadPreview");
    const publishButton = document.getElementById("publishButton");
    const selectedImages = [];

    function syncInputFiles() {
      const dataTransfer = new DataTransfer();
      selectedImages.forEach((file) => dataTransfer.items.add(file));
      imageInput.files = dataTransfer.files;
    }

    function renderPreview() {
      uploadPreview.innerHTML = "";

      selectedImages.forEach((file, index) => {
        const preview = document.createElement("div");
        preview.className = "preview-tile";
        const img = document.createElement("img");
        img.src = URL.createObjectURL(file);
        img.alt = file.name;
        img.onload = () => URL.revokeObjectURL(img.src);
        const removeButton = document.createElement("button");
        removeButton.type = "button";
        removeButton.className = "preview-remove";
        removeButton.textContent = "Remove";
        removeButton.addEventListener("click", () => {
          selectedImages.splice(index, 1);
          syncInputFiles();
          renderPreview();
        });
        preview.appendChild(img);
        preview.appendChild(removeButton);
        uploadPreview.appendChild(preview);
      });

      const isReady = selectedImages.length >= 2;
      publishButton.disabled = !isReady;
      imageHelp.textContent = isReady
        ? `${selectedImages.length} images selected. Ready to publish.`
        : `${selectedImages.length} selected. Upload at least 2 images.`;
    }

    imageInput.addEventListener("change", () => {
      [...imageInput.files].forEach((file) => {
        const alreadySelected = selectedImages.some((selectedFile) =>
          selectedFile.name === file.name &&
          selectedFile.size === file.size &&
          selectedFile.lastModified === file.lastModified
        );
        if (!alreadySelected && selectedImages.length < 8) {
          selectedImages.push(file);
        }
      });

      syncInputFiles();
      renderPreview();
    });
  </script>
  <%- include('../partials/footer') %>
</body>
</html>
