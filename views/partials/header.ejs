<header class="site-header">
  <nav class="nav-shell" aria-label="Primary navigation">
    <a class="brand" href="/">
      <span class="brand-mark">SH</span>
      <span>
        <strong>StayHub</strong>
        <small>Curated private stays</small>
      </span>
    </a>

    <div class="nav-links">
      <a href="/" class="<%= currentPage === 'Home' ? 'active' : '' %>">Residences</a>
      <a href="/bookings" class="<%= currentPage === 'bookings' ? 'active' : '' %>">Bookings</a>
      <a href="/favourites" class="<%= currentPage === 'favourite' ? 'active' : '' %>">Favourites</a>
      <a href="/host/add-home" class="<%= currentPage === 'HomeAdded' ? 'active' : '' %>">Host</a>
    </div>

    <a class="nav-cta" href="/host/add-home">List a stay</a>
  </nav>
</header>
<script>
  (() => {
    const header = document.querySelector(".site-header");
    let lastScrollY = window.scrollY;

    window.addEventListener("scroll", () => {
      const currentScrollY = window.scrollY;
      if (currentScrollY <= 12 || currentScrollY < lastScrollY) {
        header.classList.remove("header-hidden");
      } else if (currentScrollY > lastScrollY) {
        header.classList.add("header-hidden");
      }
      lastScrollY = currentScrollY;
    }, { passive: true });
  })();
</script>
