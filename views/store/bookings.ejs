<%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>

  <main class="page">
    <section class="section">
      <div class="section-title">
        <span class="eyebrow">Confirmed plans</span>
        <h1>Booked residences</h1>
        <p>Your selected stays live here, ready for review before the journey begins.</p>
      </div>

      <% if (!bookedHomes || bookedHomes.length === 0) { %>
        <div class="empty-state">
          <h2>No bookings yet.</h2>
          <p>Book a residence from the collection and it will appear here.</p>
          <a class="button" href="/">Browse stays</a>
        </div>
      <% } else { %>
        <ul class="stay-grid">
          <% bookedHomes.forEach((home)=>{ %>
            <li class="stay-card is-visible">
              <div class="stay-media">
                <% if (home.imageUrls && home.imageUrls.length > 0) { %>
                  <img src="<%= home.imageUrls[0] %>" alt="<%= home.houseName %>">
                  <% if (home.imageUrls.length > 1) { %>
                    <span class="photo-count"><%= home.imageUrls.length %> photos</span>
                  <% } %>
                <% } else { %>
                  <div class="image-fallback"><%= (home.houseName || 'S').charAt(0).toUpperCase() %></div>
                <% } %>
                <span class="rating-pill">Booked</span>
              </div>
              <div class="stay-body">
                <span class="badge">Reserved</span>
                <h3><%= home.houseName %></h3>
                <div class="location"><%= home.location %></div>
                <p class="description"><%= home.description || 'A refined residence ready for a calmer stay.' %></p>
                <div class="price-row">
                  <span class="price">Rs <%= home.Price %></span>
                  <span>per night</span>
                </div>
                <div class="card-actions">
                  <a class="button-soft" href="/homes/<%= home._id %>">Details</a>
                  <form action="/bookings/<%= home._id %>/delete" method="POST">
                    <button type="submit" class="button-danger">Cancel</button>
                  </form>
                </div>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
