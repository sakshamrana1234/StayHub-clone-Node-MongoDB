<%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>

  <main class="page">
    <section class="section">
      <div class="section-title">
        <span class="eyebrow">Your short list</span>
        <h1>Favourite residences</h1>
        <p>Keep your preferred StayHub homes close while you decide where the next quiet escape begins.</p>
      </div>

      <% if (!favouriteHomes || favouriteHomes.length === 0) { %>
        <div class="empty-state">
          <h2>No favourite stays yet.</h2>
          <p>Save residences from the collection and they will appear here.</p>
          <a class="button" href="/">Browse stays</a>
        </div>
      <% } else { %>
        <ul class="stay-grid">
          <% favouriteHomes.forEach((home)=>{ %>
            <li class="stay-card is-visible" data-detail-url="/homes/<%= home._id %>">
              <div class="stay-media">
                <% if (home.imageUrls && home.imageUrls.length > 0) { %>
                  <img src="<%= home.imageUrls[0] %>" alt="<%= home.houseName %>">
                  <% if (home.imageUrls.length > 1) { %>
                    <span class="photo-count"><%= home.imageUrls.length %> photos</span>
                  <% } %>
                <% } else { %>
                  <div class="image-fallback"><%= (home.houseName || 'S').charAt(0).toUpperCase() %></div>
                <% } %>
                <span class="rating-pill">Star <%= home.Rating || 'New' %></span>
              </div>
              <div class="stay-body">
                <span class="badge">Saved</span>
                <h3><%= home.houseName %></h3>
                <div class="location"><%= home.location %></div>
                <p class="description"><%= home.description || 'A refined residence ready for a calmer stay.' %></p>
                <div class="price-row">
                  <span class="price">Rs <%= home.Price %></span>
                  <span class="rate-label">Per night</span>
                </div>
                <div class="card-actions">
                  <a class="button-soft" href="/homes/<%= home._id %>">Details</a>
                  <form action="/bookings" method="POST">
                    <input type="hidden" name="homeId" value="<%= home._id %>">
                    <button type="submit" class="button">Book</button>
                  </form>
                  <form action="/favourites/<%= home._id %>/delete" method="POST">
                    <button type="submit" class="button-danger">Remove</button>
                  </form>
                </div>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  </main>
  <script>
    document.querySelectorAll(".stay-card[data-detail-url]").forEach((card) => {
      card.addEventListener("click", (event) => {
        if (event.target.closest("a, button, form, input")) return;
        window.location.href = card.dataset.detailUrl;
      });
    });
  </script>
  <%- include('../partials/footer') %>
</body>
</html>
