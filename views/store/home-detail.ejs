<%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>

  <main class="page">
    <section class="detail-wrap">
      <article class="detail-card">
        <div class="detail-content">
          <span class="eyebrow">StayHub residence</span>
          <h1><%= home.houseName %></h1>
          <div class="location"><%= home.location %></div>
          <p><%= home.description || 'A refined residence selected for comfort, privacy, and a slower kind of luxury.' %></p>

          <div class="detail-photo-grid" aria-label="Residence photos">
            <% if (home.imageUrls && home.imageUrls.length > 0) { %>
              <% home.imageUrls.forEach((imageUrl,imageIndex)=>{ %>
                <button type="button" class="detail-photo-card" data-image="<%= imageUrl %>" data-index="<%= imageIndex %>" aria-label="Open photo <%= imageIndex + 1 %>">
                  <img src="<%= imageUrl %>" alt="<%= home.houseName %> photo <%= imageIndex + 1 %>">
                </button>
              <% }) %>
            <% } else { %>
              <div class="image-fallback"><%= (home.houseName || 'S').charAt(0).toUpperCase() %></div>
            <% } %>
          </div>

          <div class="amenities">
            <div class="amenity rating-amenity"><span><%= home.Rating || 'New' %></span><span class="star-icon">★</span></div>
            <div class="amenity">Private host</div>
            <div class="amenity">Curated stay</div>
          </div>

          <div class="price-row">
            <span class="price">Rs <%= home.Price %></span>
            <span class="rate-label">Per night</span>
          </div>

          <div class="detail-actions">
            <form action="/bookings" method="POST">
              <input type="hidden" name="homeId" value="<%= home._id %>">
              <button type="submit" class="button">Book residence</button>
            </form>
            <form action="/favourites" method="POST">
              <input type="hidden" name="homeId" value="<%= home._id %>">
              <button type="submit" class="button-soft">♡ Add to wishlist</button>
            </form>
            <a class="button-soft" href="/">Back to residences</a>
          </div>
        </div>
      </article>
    </section>
  </main>
  <div class="lightbox" id="imageLightbox" aria-hidden="true">
    <button type="button" class="lightbox-close" aria-label="Close image">Close</button>
    <button type="button" class="lightbox-arrow lightbox-prev" aria-label="Previous image">‹</button>
    <img src="" alt="Full residence photo" id="lightboxImage">
    <button type="button" class="lightbox-arrow lightbox-next" aria-label="Next image">›</button>
  </div>
  <script>
    const lightbox = document.getElementById("imageLightbox");
    const lightboxImage = document.getElementById("lightboxImage");
    const closeLightbox = document.querySelector(".lightbox-close");
    const prevImage = document.querySelector(".lightbox-prev");
    const nextImage = document.querySelector(".lightbox-next");
    const photos = [...document.querySelectorAll(".detail-photo-card")].map((photo) => photo.dataset.image);
    let currentImageIndex = 0;

    function showImage(index) {
      if (photos.length === 0) return;
      currentImageIndex = (index + photos.length) % photos.length;
      lightboxImage.src = photos[currentImageIndex];
    }

    document.querySelectorAll(".detail-photo-card").forEach((photo) => {
      photo.addEventListener("click", () => {
        showImage(Number(photo.dataset.index || 0));
        lightbox.classList.add("open");
        lightbox.setAttribute("aria-hidden", "false");
      });
    });

    closeLightbox.addEventListener("click", () => {
      lightbox.classList.remove("open");
      lightbox.setAttribute("aria-hidden", "true");
      lightboxImage.src = "";
    });

    prevImage.addEventListener("click", (event) => {
      event.stopPropagation();
      showImage(currentImageIndex - 1);
    });

    nextImage.addEventListener("click", (event) => {
      event.stopPropagation();
      showImage(currentImageIndex + 1);
    });

    lightbox.addEventListener("click", (event) => {
      if (event.target === lightbox) {
        closeLightbox.click();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (!lightbox.classList.contains("open")) return;
      if (event.key === "Escape") closeLightbox.click();
      if (event.key === "ArrowLeft") showImage(currentImageIndex - 1);
      if (event.key === "ArrowRight") showImage(currentImageIndex + 1);
    });
  </script>
  <%- include('../partials/footer') %>
</body>
</html>
