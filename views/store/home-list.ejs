<%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>

  <main class="page">
    <section class="hero">
      <div>
        <span class="eyebrow">StayHub private collection</span>
        <h1>Old-world stays for modern escapes.</h1>
        <p>Browse character-rich residences, quiet retreats, and polished homes selected with a more considered sense of luxury.</p>
        <div class="hero-actions">
          <a class="button" href="#residences">Explore residences</a>
          <a class="button-soft" href="/host/add-home">Become a host</a>
        </div>
      </div>
      <div class="hero-panel" aria-label="Luxury private residence">
        <div class="hero-card">
          <strong>Handpicked comfort, no noisy excess.</strong>
        </div>
      </div>
    </section>

    <section class="quick-panel" aria-label="Residence filters">
      <div class="filters">
        <input id="staySearch" type="search" placeholder="Search by stay or location">
        <select id="priceFilter">
          <option value="all">All prices</option>
          <option value="under2000">Under Rs 2000</option>
          <option value="2000to5000">Rs 2000 - Rs 5000</option>
          <option value="over5000">Over Rs 5000</option>
        </select>
        <select id="sortFilter">
          <option value="featured">Featured</option>
          <option value="priceLow">Price low to high</option>
          <option value="priceHigh">Price high to low</option>
          <option value="ratingHigh">Top rated</option>
        </select>
      </div>
      <div class="stats-strip">
        <div class="stat"><strong><%= houseNames.length %></strong><span>Residences</span></div>
        <div class="stat"><strong>24/7</strong><span>Host support</span></div>
        <div class="stat"><strong>Elite</strong><span>Curated stays</span></div>
      </div>
    </section>

    <section class="section" id="residences">
      <div class="section-title">
        <span class="eyebrow">Available now</span>
        <h2>Signature residences</h2>
        <p>Save favourites, open full details, or remove listings you no longer want to showcase.</p>
      </div>

      <% if (!houseNames || houseNames.length === 0) { %>
        <div class="empty-state">
          <h2>No residences yet.</h2>
          <p>Add your first StayHub property and it will appear here.</p>
          <a class="button" href="/host/add-home">Add a stay</a>
        </div>
      <% } else { %>
        <ul class="stay-grid" id="stayGrid">
          <% houseNames.forEach((home)=>{ %>
            <li class="stay-card" data-detail-url="/homes/<%= home._id %>" data-name="<%= home.houseName %>" data-location="<%= home.location %>" data-price="<%= home.Price || 0 %>" data-rating="<%= home.Rating || 0 %>">
              <div class="stay-media gallery-card" data-index="0">
                <% if (home.imageUrls && home.imageUrls.length > 0) { %>
                  <% home.imageUrls.forEach((imageUrl, imageIndex)=>{ %>
                    <img src="<%= imageUrl %>" alt="<%= home.houseName %> photo <%= imageIndex + 1 %>" class="<%= imageIndex === 0 ? 'active' : '' %>">
                  <% }) %>
                  <% if (home.imageUrls.length > 1) { %>
                    <button class="gallery-arrow prev" type="button" aria-label="Previous photo">‹</button>
                    <button class="gallery-arrow next" type="button" aria-label="Next photo">›</button>
                    <span class="photo-count"><%= home.imageUrls.length %> photos</span>
                  <% } %>
                <% } else { %>
                  <div class="image-fallback"><%= (home.houseName || 'S').charAt(0).toUpperCase() %></div>
                <% } %>
                <span class="rating-pill">Star <%= home.Rating || 'New' %></span>
              </div>
              <div class="stay-body">
                <span class="badge">Private stay</span>
                <h3><%= home.houseName %></h3>
                <div class="location"><%= home.location %></div>
                <p class="description"><%= home.description || 'A refined residence ready for a calmer stay.' %></p>
                <div class="price-row">
                  <span class="price">Rs <%= home.Price %></span>
                  <span class="rate-label">Per night</span>
                </div>
                <div class="card-actions">
                  <a class="button-soft" href="/homes/<%= home._id %>">Details</a>
                  <form action="/bookings" method="POST">
                    <input type="hidden" name="homeId" value="<%= home._id %>">
                    <button type="submit" class="button">Book</button>
                  </form>
                  <form action="/favourites" method="POST">
                    <input type="hidden" name="homeId" value="<%= home._id %>">
                    <button type="submit" class="icon-button" aria-label="Add to wishlist">♡</button>
                  </form>
                  <form action="/host/delete-home/<%= home._id %>" method="POST">
                    <button type="submit" class="button-danger">Delete</button>
                  </form>
                </div>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  </main>

  <div class="toast" id="toast">Filters updated</div>
  <script>
    const cards = [...document.querySelectorAll(".stay-card")];
    const grid = document.getElementById("stayGrid");
    const search = document.getElementById("staySearch");
    const priceFilter = document.getElementById("priceFilter");
    const sortFilter = document.getElementById("sortFilter");
    const toast = document.getElementById("toast");

    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.16 });

    cards.forEach((card) => revealObserver.observe(card));

    function showToast() {
      toast.classList.add("show");
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => toast.classList.remove("show"), 900);
    }

    function matchesPrice(price, filter) {
      if (filter === "under2000") return price < 2000;
      if (filter === "2000to5000") return price >= 2000 && price <= 5000;
      if (filter === "over5000") return price > 5000;
      return true;
    }

    function applyFilters() {
      const term = search.value.trim().toLowerCase();
      const priceValue = priceFilter.value;
      const sortValue = sortFilter.value;
      const visibleCards = cards.filter((card) => {
        const haystack = `${card.dataset.name} ${card.dataset.location}`.toLowerCase();
        const price = Number(card.dataset.price || 0);
        const isVisible = haystack.includes(term) && matchesPrice(price, priceValue);
        card.style.display = isVisible ? "" : "none";
        return isVisible;
      });

      visibleCards
        .sort((a, b) => {
          if (sortValue === "priceLow") return Number(a.dataset.price) - Number(b.dataset.price);
          if (sortValue === "priceHigh") return Number(b.dataset.price) - Number(a.dataset.price);
          if (sortValue === "ratingHigh") return Number(b.dataset.rating) - Number(a.dataset.rating);
          return 0;
        })
        .forEach((card) => grid.appendChild(card));

      showToast();
    }

    [search, priceFilter, sortFilter].forEach((control) => {
      control.addEventListener("input", applyFilters);
      control.addEventListener("change", applyFilters);
    });

    document.querySelectorAll(".gallery-card").forEach((gallery) => {
      const images = [...gallery.querySelectorAll("img")];
      if (images.length <= 1) return;

      function showImage(nextIndex) {
        const safeIndex = (nextIndex + images.length) % images.length;
        gallery.dataset.index = safeIndex;
        images.forEach((img, index) => img.classList.toggle("active", index === safeIndex));
      }

      gallery.querySelector(".next")?.addEventListener("click", (event) => {
        event.preventDefault();
        showImage(Number(gallery.dataset.index || 0) + 1);
      });

      gallery.querySelector(".prev")?.addEventListener("click", (event) => {
        event.preventDefault();
        showImage(Number(gallery.dataset.index || 0) - 1);
      });

      gallery.addEventListener("mouseenter", () => showImage(Number(gallery.dataset.index || 0) + 1));
    });

    document.querySelectorAll(".stay-card[data-detail-url]").forEach((card) => {
      card.addEventListener("click", (event) => {
        if (event.target.closest("a, button, form, input")) return;
        window.location.href = card.dataset.detailUrl;
      });
    });
  </script>
  <%- include('../partials/footer') %>
</body>
</html>
