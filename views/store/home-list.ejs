<%- include('../partials/head') %>

<%- include('../partials/header') %>

<body class="bg-gradient-to-r from-blue-50 to-purple-50 min-h-screen">
  
<h1 class="animate-pulse text-4xl font-bold text-center text-purple-500 shadow-2xs mt-10 mb-12 animate-fade-in-down">
  Welcome to Our Homes
  </h1>
   
   
  <ul class="max-w-6xl mx-auto max-h-6x5 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 px-4 pb-2 ">
  <% houseNames.forEach((home)=>{ %>
  <li class="bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 overflow-hidden border border-indigo-100">
    <div class="relative">
    <div class="relative">
    
      <img src="data:image/jpeg;base64," alt="House" class="w-full h-48 object-cover">
      <span class="absolute top-2 right-2 bg-yellow-400 text-xs font-bold px-2 py-1 rounded-full">
      ★<%= home.rating %>
      </span>
    </div>
    <div class="p-6">
      <h2 class="text-xl font-semibold text-gray-800 mb-2">
      <%= home.houseName %>
      </h2>
      <div class="flex items-center text-gray-600 mb-2">
      <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
        <path d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"/>
      </svg>
      <%= home.location %>
      </div>
      <div class="flex items-center text-red-600 font-medium ">
      
      Rs <%= home.Price %>
    
      </div>
      <div class=" gap-6 mt-3 flex">
      <a class="bg-yellow-400 mt-2.5" href="homes/<%= home._id %>">Details</a>
          <form action="/favourites" method="POST">
    <button type="submit" class="bg-blue-300   mt-3">Add to favourite</button>
    <input type="hidden" name="homeId" value="<%= home._id %>">
  
  </form>
   <form action="/host/delete-home/<%= home._id %>" method="POST">
                <button type="submit" class="bg-red-400 mt-2.5">Delete</button>
              </form>
  </div>
    </div>
    </li>

  <% }) %> 
 
  </ul>
</body>
</html>